{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vision_result.schema.json",
  "title": "VisionResult",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "task_id", "ingredients", "nutrition_facts", "meta"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "food_name": {
      "type": "string"
    },
    "brand": {
      "type": "string"
    },
    "ingredients": {
      "type": "object",
      "additionalProperties": true,
      "required": ["items"],
      "properties": {
        "raw_text": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "nutrition_facts": {
      "type": "object",
      "additionalProperties": true,
      "required": ["items"],
      "properties": {
        "raw_text": {
          "type": "string"
        },
        "serving_size": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/NutritionItem"
          }
        }
      }
    },
    "expiration_date": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "raw_text": {
          "type": "string"
        },
        "value": {
          "type": ["string", "null"]
        }
      }
    },
    "detected_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ocr_text_blocks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/OcrTextBlock"
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "NutritionItem": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string"
        },
        "per_100g": {
          "type": "string"
        },
        "per_serving": {
          "type": "string"
        },
        "nrv": {
          "type": "string"
        }
      }
    },
    "OcrTextBlock": {
      "type": "object",
      "additionalProperties": true,
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "bbox": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "number"
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}

