# ==========================================
# 操作系统与通用文件 (OS & General)
# ==========================================
.DS_Store
Thumbs.db
*.swp
*~
.vscode/
.idea/
*.log

# ==========================================
# 敏感信息与环境配置 (Secrets & Env)
# ==========================================
# 绝对不能提交生产环境的密钥
.env
.env.local
.env.*.local
backend/.env
!backend/.env.example
docker/.env
!docker/.env.example

# ==========================================
# 后端与算法 (Python - Backend & Algorithm)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# 算法模型文件（体积巨大，建议通过脚本下载或挂载）
*.pth
*.weights
*.bin
*.onnx
*.pkl
algorithm/models/
algorithm/data/hard_samples/

# ==========================================
# 前端 (Node.js - Frontend/Uni-app)
# ==========================================
frontend/node_modules/
frontend/unpackage/
frontend/dist/
frontend/.hbuilderx/
.npm
.eslintcache

# ==========================================
# 基础设施与本地数据 (Docker & Data)
# ==========================================
# 排除本地持久化挂载的数据，防止数据库内容进入 Git
docker/pg_data/
docker/minio_data/
docker/milvus_data/
docker/redis_data/
backend/mysql-data/
backend/redis-data/

# ==========================================
# 文档与临时资产 (Docs & Temp)
# ==========================================
docs/temp/
*.pdf

# 如果有需要保留的说明文档 PDF 则排除在外（重新允许跟踪）
!docs/*.pdf

# 测试代码
test*.py